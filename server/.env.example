# Server
PORT=3000
NODE_ENV=development

# MySQL
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_password
DB_NAME=atlantic_stars

# JWT
JWT_SECRET=your_jwt_secret_change_this
JWT_EXPIRES_IN=7d

# Tencent COS
COS_SECRET_ID=your_cos_secret_id
